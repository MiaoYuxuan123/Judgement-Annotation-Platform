<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.nju.jap.mapper.AuthTokenMapper">
    <insert id="insert">INSERT INTO auth_token(token, user_id) VALUES (#{token}, #{userId})</insert>
    <select id="selectUserId" resultType="long">SELECT user_id FROM auth_token WHERE token=#{token}</select>
    <delete id="deleteByToken">DELETE FROM auth_token WHERE token=#{token}</delete>
</mapper>
