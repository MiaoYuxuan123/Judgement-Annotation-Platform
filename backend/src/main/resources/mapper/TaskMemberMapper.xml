<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="edu.nju.jap.mapper.TaskMemberMapper">
    <select id="selectByTaskId" resultType="edu.nju.jap.model.po.TaskMember">
        SELECT * FROM task_member WHERE task_id=#{taskId}
    </select>
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO task_member(task_id, user_id, role_in_task) VALUES (#{taskId}, #{userId}, #{roleInTask})
    </insert>
    <delete id="deleteByTaskId">DELETE FROM task_member WHERE task_id=#{taskId}</delete>
</mapper>
